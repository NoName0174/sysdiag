    for sev, title, detail, fix_label, msg in items:
        prob = Problem(sev, title, detail, fix_label)
        prob.fix_fn = _rm(prob, msg)
        _test_problems.append(prob)
    return _test_problems

# ── data ──────────────────────────────────────────────────────────────────────
class Data:
    def __init__(self):
        self.lock = threading.Lock()
        self.d = {}
        self.prev_net = {}
        self.prev_disk = {}
        self.prev_time = time.time()
        self.cpu_hist = []
        self.mem_hist = []
        self.collect()

    def collect(self):
        d = {}

        # cpu
        def cpu_stat():
            line = Path("/proc/stat").read_text().splitlines()[0].split()
            v = list(map(int, line[1:]))
            return sum(v), v[3]
        def core_stats():
            lines = [l for l in Path("/proc/stat").read_text().splitlines() if re.match(r"cpu\d",l)]
            return [(sum(v:=list(map(int,l.split()[1:]))), v[3]) for l in lines]

        t1,i1 = cpu_stat(); c1 = core_stats()
        time.sleep(0.5)
        t2,i2 = cpu_stat(); c2 = core_stats()
        dt = t2-t1
        d["cpu_pct"] = round(100*(dt-(i2-i1))/dt) if dt else 0
        d["cpu_cores"] = []
        for (ct1,ci1),(ct2,ci2) in zip(c1,c2):
            dct = ct2-ct1
            d["cpu_cores"].append(round(100*(dct-(ci2-ci1))/dct) if dct else 0)
        stat = Path("/proc/stat").read_text()
        d["ctx"]  = re.search(r"^ctxt (\d+)",  stat, re.M).group(1) if re.search(r"^ctxt",  stat, re.M) else "?"
        d["intr"] = re.search(r"^intr (\d+)",  stat, re.M).group(1) if re.search(r"^intr",  stat, re.M) else "?"
        iv = list(map(int, stat.splitlines()[0].split()[1:]))
        it = sum(iv)
        d["iowait"] = f"{100*iv[4]/it:.1f}" if it else "0"
        try:
            d["cpu_freq"] = f"{int(read('/sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq'))//1000} MHz"
        except:
            d["cpu_freq"] = "n/a"

        d["cpu_hist"] = (self.cpu_hist + [d["cpu_pct"]])[-40:]
        self.cpu_hist = d["cpu_hist"]

        # temps
        d["temps"] = []
        for zone in sorted(Path("/sys/class/thermal").glob("thermal_zone*")):
            t = read(zone/"temp")
            if t: d["temps"].append(f"{read(zone/'type')}:{int(t)//1000}C")

        # fans
        d["fans"] = []
        for hwmon in sorted(Path("/sys/class/hwmon").glob("hwmon*")):
            for f in sorted(hwmon.glob("fan*_input")):
                v = read(f)
                if v and v != "0":
                    lbl = read(str(f).replace("_input","_label")) or f.name
                    d["fans"].append(f"{lbl}:{v} RPM")

        # memory
        mem = {}
        for line in Path("/proc/meminfo").read_text().splitlines():
            p = line.split(":")
            if len(p)==2:
                try: mem[p[0].strip()] = int(p[1].strip().split()[0])
                except: pass
        d["mem_total"]  = mem.get("MemTotal",0)
        d["mem_avail"]  = mem.get("MemAvailable",0)
        d["mem_used"]   = d["mem_total"]-d["mem_avail"]
        d["mem_pct"]    = round(d["mem_used"]*100/d["mem_total"]) if d["mem_total"] else 0
        d["dirty_mb"]   = mem.get("Dirty",0)//1024
        d["wb_mb"]      = mem.get("Writeback",0)//1024
        d["huge_total"] = mem.get("HugePages_Total",0)
        d["huge_free"]  = mem.get("HugePages_Free",0)
        d["swap_total"] = mem.get("SwapTotal",0)
        d["swap_used"]  = d["swap_total"]-mem.get("SwapFree",0)
        errs = 0
        edac = Path("/sys/devices/system/edac/mc")
        if edac.exists():
            for f in list(edac.glob("*/ce_count"))+list(edac.glob("*/ue_count")):
                try: errs += int(read(f))
                except: pass
        d["mem_errors"] = errs

        d["mem_hist"] = (self.mem_hist + [d["mem_pct"]])[-40:]
        self.mem_hist = d["mem_hist"]

        # gpu
        if os.path.exists("/usr/bin/nvidia-smi"):
            d["gpu"] = sh("nvidia-smi --query-gpu=name,utilization.gpu,temperature.gpu --format=csv,noheader,nounits")
        elif Path("/sys/class/drm/card0/device/gpu_busy_percent").exists():
            d["gpu"] = f"integrated  {read('/sys/class/drm/card0/device/gpu_busy_percent')}% busy"
        else:
            d["gpu"] = "no GPU data"

        # smart
        d["smart"] = []
        for dev in ["/dev/nvme0","/dev/sda","/dev/sdb"]:
            if Path(dev).exists():
                out = sh(f"sudo -n smartctl -H {dev}")
                m = re.search(r"(?:overall-health|result).*?:\s*(\S+)", out, re.I)
                if m: d["smart"].append((dev, m.group(1)))
        if not d["smart"]: d["smart"] = [("n/a","run as root")]

        # processes
        d["procs"] = []
        for line in sh("ps --no-headers -eo pid,comm,%cpu --sort=-%cpu").splitlines()[:5]:
            p = line.split(None,2)
            if len(p)==3: d["procs"].append(p)
        d["zombies"]    = sh("ps --no-headers -eo stat | grep -c '^Z'","0")
        d["oom_events"] = sh("journalctl -k --since today 2>/dev/null | grep -c 'Out of memory\\|oom_kill'","0")

        # load / uptime
        try:
            load = Path("/proc/loadavg").read_text().split()
            d["load"] = " ".join(load[:3])
            ut = float(read("/proc/uptime","0").split()[0])
            d["uptime_days"] = ut / 86400
        except: pass

        # systemd
        d["failed_units"] = [l for l in sh("systemctl --failed --no-legend").splitlines() if l.strip()]
        d["journal_errs"] = sh("journalctl -p err -n 4 --no-pager --no-hostname -o short").splitlines()

        # journal size
        try:
            out = sh("journalctl --disk-usage 2>/dev/null")
            m = re.search(r"([\d.]+)\s*(\w)", out)
            if m:
                val, unit = float(m.group(1)), m.group(2)
                mult = {"K":1,"M":1,"G":1024,"T":1024*1024}
                d["journal_size_mb"] = val * mult.get(unit, 1)
        except: pass

        # dmesg
        d["dmesg"] = sh("dmesg --level=warn,err,crit,alert,emerg").splitlines()[-5:]

        # network
        d["iface"]    = sh("ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i==\"dev\") print $(i+1)}'")
        d["ip"]       = sh(f"ip -4 addr show {d['iface']} 2>/dev/null | awk '/inet /{{print $2}}' | cut -d/ -f1")
        d["gw"]       = sh("ip route 2>/dev/null | awk '/default/{print $3; exit}'")
        d["ping_gw"]  = sh(f"ping -c1 -W1 {d['gw']} 2>/dev/null | awk -F'/' '/rtt/{{printf \"%.1fms\",$5}}'","timeout")
        d["ping_ext"] = sh("ping -c1 -W1 1.1.1.1 2>/dev/null | awk -F'/' '/rtt/{printf \"%.1fms\",$5}'","timeout")
        d["dns_ms"]   = sh("bash -c 't=$(($(date +%s%3N))); drill archlinux.org @1.1.1.1 >/dev/null 2>&1; echo $(($(date +%s%3N)-t))'","n/a")
        d["ports"]    = sh("ss -tlnp 2>/dev/null | awk 'NR>1{print $4}' | grep -oP ':\\K\\d+' | sort -un | tr '\\n' ' '")
        d["fw"] = sh("sudo -n iptables -L INPUT -n 2>/dev/null | grep -cE '^(ACCEPT|DROP|REJECT)'","n/a")

        # network throughput (monitor mode)
        try:
            net_raw = {}
            for line in Path("/proc/net/dev").read_text().splitlines()[2:]:
                parts = line.split()
                iface = parts[0].rstrip(":")
                if iface != "lo":
                    net_raw[iface] = (int(parts[1]), int(parts[9]))
            now = time.time()
            dt_net = now - self.prev_time
            if self.prev_net and dt_net > 0:
                rates = {}
                for iface, (rx, tx) in net_raw.items():
                    if iface in self.prev_net:
                        drx = max(0, (rx - self.prev_net[iface][0]) / dt_net)
                        dtx = max(0, (tx - self.prev_net[iface][1]) / dt_net)
                        rates[iface] = (drx, dtx)
                if rates: d["net_rates"] = rates
            self.prev_net = net_raw
            self.prev_time = now
        except: pass

        # disk throughput (monitor mode)
        try:
            disk_raw = {}
            for dev_path in sorted(Path("/sys/block").iterdir()):
                name = dev_path.name
                if name.startswith(("sd","nvme","vd","mmc")):
                    st = dev_path / "stat"
                    if st.exists():
                        f = st.read_text().split()
                        disk_raw[name] = (int(f[2])*512, int(f[6])*512)
            if self.prev_disk and dt_net > 0:
                rates = {}
                for dev, (r, w) in disk_raw.items():
                    if dev in self.prev_disk:
                        dr = max(0, (r - self.prev_disk[dev][0]) / dt_net)
                        dw = max(0, (w - self.prev_disk[dev][1]) / dt_net)
                        rates[dev] = (dr, dw)
                if rates: d["disk_rates"] = rates
            self.prev_disk = disk_raw
        except: pass

        # battery
        try:
            bat = Path("/sys/class/power_supply/BAT0")
            if bat.exists():
                ed = read(bat/"energy_full_design") or read(bat/"charge_full_design")
                en = read(bat/"energy_full") or read(bat/"charge_full")
                enow = read(bat/"energy_now") or read(bat/"charge_now")
                if ed and en:
                    ed_v, en_v = float(ed), float(en)
                    d["battery_design"] = round(ed_v / 1e6, 1) if ed_v > 1e9 else round(ed_v / 1e3, 1)
                    d["battery_now"] = round(en_v / 1e6, 1) if en_v > 1e9 else round(en_v / 1e3, 1)
                    d["battery_wear"] = max(0, 100 * (ed_v - en_v) / ed_v) if ed_v else 0
                if enow and en:
                    enow_v, en_v = float(enow), float(en)
                    d["battery_pct"] = round(100 * enow_v / en_v) if en_v else 0
                d["battery_status"] = read(bat/"status","unknown")
        except: pass

        # security
        d["last_logins"] = [l for l in sh("last -n 4 --time-format iso 2>/dev/null").splitlines() if l and "wtmp" not in l][:4]
        d["ssh_fails"]   = sh("journalctl _SYSTEMD_UNIT=sshd.service 2>/dev/null | grep -c 'Failed password\\|Invalid user'","0")
        d["suid"]        = sh("find /usr/bin /usr/sbin /bin /sbin -perm /4000 2>/dev/null | wc -l","?")
        updates_cmds = [
            ("pacman","checkupdates 2>/dev/null | wc -l","pacman -Qu 2>/dev/null | wc -l"),
            ("apt-get","apt list --upgradable 2>/dev/null | grep -c upgradable",""),
            ("dnf","dnf check-update --quiet 2>/dev/null | wc -l",""),
            ("zypper","zypper list-updates 2>/dev/null | wc -l",""),
            ("xbps-install","xbps-install -un 2>/dev/null | wc -l",""),
        ]
        upd = "n/a"
        for pm,cmd,alt in updates_cmds:
            if shutil.which(pm):
                upd = sh(cmd, sh(alt,"n/a") if alt else "n/a")
                if not upd.isdigit(): upd = "n/a"
                break
        d["updates"] = upd

        # partitions (with used_frac for problem detection)
        d["disks"] = []
        try:
            raw = sh("lsblk -Jbpo NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT,LABEL")
            blk = json.loads(raw)

            df_data = {}
            for line in sh("df -B1 --output=source,used,avail 2>/dev/null").splitlines()[1:]:
                pf = line.split()
                if len(pf)==3:
                    df_data[pf[0]] = (int(pf[1]), int(pf[2]))

            findmnt_data = {}
            for line in sh("findmnt -rno SOURCE,TARGET 2>/dev/null").splitlines():
                pf = line.split(None,1)
                if len(pf)==2:
                    dev_name = re.sub(r'\[.*?\]','',pf[0])
                    findmnt_data.setdefault(dev_name,[]).append(pf[1])

            for dev in blk.get("blockdevices",[]):
                disk_size = int(dev.get("size") or 0)
                children  = dev.get("children") or []
                parts = []
                for child in children:
                    csize  = int(child.get("size") or 0)
                    cname  = child.get("name") or "?"
                    used,avail = df_data.get(cname,(None,None))
                    mounts = findmnt_data.get(cname,[])
                    parts.append({
                        "name":   cname,
                        "size_b": csize,
                        "size":   human(csize),
                        "fstype": child.get("fstype") or "",
                        "mounts": mounts,
                        "label":  child.get("label") or "",
                        "used":   human(used) if used is not None else "",
                        "avail":  human(avail) if avail is not None else "",
                        "used_b": used or 0,
                        "used_frac": used/csize if used and csize else 0,
                    })

                unalloc = disk_size - sum(pt["size_b"] for pt in parts)
                if unalloc > 1024*1024:
                    parts.append({
                        "name":"unallocated","size_b":unalloc,"size":human(unalloc),
                        "fstype":"","mounts":[],"label":"","used":"","avail":"",
                        "used_b":0,"used_frac":0,
                    })

                d["disks"].append({
                    "name":   dev.get("name") or "?",
                    "size":   human(disk_size),
                    "size_b": disk_size,
                    "label":  dev.get("label") or "",
                    "parts":  parts,
                })
        except Exception:
            pass

        with self.lock:
            self.d = d

    def get(self):
        with self.lock:
            return dict(self.d)

# ── draw: default mode (repair menu) ──────────────────────────────────────────
def draw_default(stdscr, data_obj, test_mode=False):
    curses.curs_set(0)
    stdscr.nodelay(True)
    stdscr.timeout(200)
    curses.start_color()
    curses.use_default_colors()

    accent = load_accent()
    if accent and curses.can_change_color():
        r,g,b = accent
        curses.init_color(10, r*1000//255, g*1000//255, b*1000//255)
        curses.init_pair(1, 10, -1)
    else:
        curses.init_pair(1, curses.COLOR_YELLOW, -1)
    curses.init_pair(2, curses.COLOR_WHITE,  -1)
    curses.init_pair(3, curses.COLOR_GREEN,  -1)
    curses.init_pair(4, curses.COLOR_RED,    -1)
    curses.init_pair(5, curses.COLOR_YELLOW, -1)
    curses.init_pair(6, curses.COLOR_CYAN,   -1)
    curses.init_pair(7, curses.COLOR_MAGENTA,-1)

    AC = curses.color_pair(1)
    NM = curses.color_pair(2)
    OK = curses.color_pair(3)
    ER = curses.color_pair(4)
    WN = curses.color_pair(5)
    DM = curses.color_pair(6)
    MG = curses.color_pair(7)

    last_refresh = 0
    fix_msg = ""
    fix_msg_timer = 0
    pending_fix = None
    sel = 0

    while True:
        key = stdscr.getch()
        if key in (ord('q'), ord('Q')) and pending_fix is None:
            break
        if key == 27 and pending_fix is None:
            break

        now = time.time()
        if now - last_refresh >= REFRESH:
            threading.Thread(target=data_obj.collect, daemon=True).start()
            last_refresh = now

        if fix_msg and now - fix_msg_timer > 4:
            fix_msg = ""

        d = data_obj.get()
        if not d:
            continue

        H, W = stdscr.getmaxyx()
        if H < 10 or W < 40:
            stdscr.erase()
            sadd(stdscr, 0, 0, "Terminal too small", ER | curses.A_BOLD)
            stdscr.refresh()
            continue
        stdscr.erase()

        hn = sh("uname -n")
        ts = time.strftime("%H:%M")

        # ── data ───────────────────────────────────────────────────────────────
        problems = test_problems() if test_mode else detect_problems(d)
        fixable = [(i, pr) for i, pr in enumerate(problems) if pr.fix_fn]

        if problems:
            sel = max(0, min(sel, len(problems) - 1))
        else:
            sel = 0

        cpu = d.get("cpu_pct", 0)
        mu = d.get("mem_used", 0); mt = d.get("mem_total", 1)
        mp = d.get("mem_pct", 0)
        load = d.get("load", "?")
        upt = d.get("uptime_days", 0)
        temp_tags = []
        for t in d.get("temps", []):
            if ":" in t:
                lbl, val = t.rsplit(":", 1)
                temp_tags.append(f"{lbl[:6]}:{val}")
        temps_str = "  ".join(temp_tags[:4]) if temp_tags else ""

        n_crit = sum(1 for pr in problems if pr.severity >= 2)
        n_warn = sum(1 for pr in problems if pr.severity == SEV_WARN)
        n_info = sum(1 for pr in problems if pr.severity == SEV_INFO)
        tag_parts = []
        if n_crit: tag_parts.append(f"{n_crit} critical")
        if n_warn: tag_parts.append(f"{n_warn} warning")
        if n_info: tag_parts.append(f"{n_info} info")
        tag_str = ", ".join(tag_parts) if tag_parts else "none"

        # ── header ─────────────────────────────────────────────────────────────
        for i in range(H):
            for j in range(W):
                ch = ' '
                if i == 0 and j == 0: ch = '┌'
                elif i == 0 and j == W - 1: ch = '┐'
                elif i == H - 1 and j == 0: ch = '└'
                elif i == H - 1 and j == W - 1: ch = '┘'
                elif i == 0 or i == H - 1: ch = '─'
                elif j == 0 or j == W - 1: ch = '│'
                sadd(stdscr, i, j, ch, AC)
        tag = " [TEST MODE]" if test_mode else ""
        sadd(stdscr, 0, 2, f" sysdiag{tag} — {hn}  {ts}"[:W - 4], AC | curses.A_BOLD)

        # ── list header ────────────────────────────────────────────────────────
        cnt = f"Issues ({tag_str})"
        y = 2
        sadd(stdscr, y, 2, cnt[:W - 4], AC | curses.A_BOLD)
        y += 1
        for x in range(2, W - 2):
            sadd(stdscr, y, x, "─", DM)
        y += 1

        # ── items ──────────────────────────────────────────────────────────────
        max_y = H - 6
        if not problems:
            sadd(stdscr, y, 4, "✓  No problems detected", OK | curses.A_BOLD)
            y = max_y
        else:
            for idx, prob in enumerate(problems):
                if y >= max_y: break
                _, fi_idx = next(((fi, i) for fi, (i, _) in enumerate(fixable) if i == idx), (None, None))
                is_sel = (idx == sel)
                sev_tag = "CRIT" if prob.severity >= 2 else "WARN" if prob.severity == SEV_WARN else "INFO"
                col = ER if prob.severity >= 2 else WN if prob.severity == SEV_WARN else DM
                text = f"{sev_tag}  {prob.title}"
                if is_sel:
                    for x in range(2, W - 2):
                        sadd(stdscr, y, x, " ", AC | curses.A_REVERSE)
                    sadd(stdscr, y, 3, f"▸ {text}"[:W - 6], AC | curses.A_REVERSE | curses.A_BOLD)
                    if fi_idx is not None:
                        sadd(stdscr, y, W - 5 - len(str(fi_idx + 1)), f"[{fi_idx + 1}]", MG | curses.A_BOLD)
                else:
                    sadd(stdscr, y, 3, f"  {text}"[:W - 6], col | curses.A_BOLD)
                    if fi_idx is not None:
                        sadd(stdscr, y, W - 5 - len(str(fi_idx + 1)), f"[{fi_idx + 1}]", MG | curses.A_BOLD)
                y += 1

        # ── separator before info ──────────────────────────────────────────────
        y = max(y, H - 5)
        for x in range(2, W - 2):
            sadd(stdscr, y, x, "─", DM)
        y += 1

        # ── system info ────────────────────────────────────────────────────────
        l1 = f"CPU {cpu}% {bar(cpu,10)}  Mem {gb(mu)}/{gb(mt)}GB {bar(mp,6)}  Load {load}"
        sadd(stdscr, y, 2, l1[:W - 4], DM)
        y += 1
        parts = []
        if temps_str: parts.append(temps_str)
        parts.append(f"Up {upt:.1f}d")
        if d.get("ip"): parts.append(f"IP {d['ip']}")
        if d.get("battery_pct") is not None: parts.append(f"Bat {d['battery_pct']}%")
        parts.append(f"Updates {d.get('updates','?')}")
        sadd(stdscr, y, 2, "  ".join(parts)[:W - 4], DM)

        # ── footer bar ─────────────────────────────────────────────────────────
        footer = "q quit"
        if test_mode:
            footer = "TEST MODE  " + footer
        if _fix_busy.is_set():
            footer = "  fixing...  " + footer
        elif fix_msg:
            footer = "  " + fix_msg + "  " + footer
        if problems and not _fix_busy.is_set():
            footer += "  |  ↑↓  enter"
        for x in range(1, W - 1):
            sadd(stdscr, H - 1, x, " ", AC | curses.A_REVERSE)
        sadd(stdscr, H - 1, 2, footer[:W - 4], AC | curses.A_REVERSE)

        # ── info / fix overlay ──────────────────────────────────────────────────
        if pending_fix is not None:
            idx, pr = pending_fix
            has_fix = pr.fix_fn is not None
            bw = min(56, W - 4)
            bh = 9 if has_fix else 8
            bx = (W - bw) // 2
            by = (H - bh) // 2
            col = ER if pr.severity >= 2 else WN
            sev = "CRITICAL" if pr.severity >= 2 else "WARNING" if pr.severity == SEV_WARN else "INFO"

            for y in range(bh):
                for x in range(bw):
                    ch = ' '
                    if y == 0: ch = '─'
                    if x == 0: ch = '│'
                    if y == 0 and x == 0: ch = '┌'
                    if y == 0 and x == bw-1: ch = '┐'
                    if y == bh-1 and x == 0: ch = '└'
                    if y == bh-1 and x == bw-1: ch = '┘'
                    if 0 < y < bh-1 and 0 < x < bw-1: ch = ' '
                    if y == bh-1 and 0 < x < bw-1: ch = '─'
                    sadd(stdscr, by+y, bx+x, ch, AC if (y==0 or y==bh-1 or x==0 or x==bw-1) else 0)

            sadd(stdscr, by, bx+2, f" {sev} ", col | curses.A_BOLD)
            sadd(stdscr, by+2, bx+2, pr.title[:bw-4], col | curses.A_BOLD)
            for i, line in enumerate(pr.detail.split('\n')[:2]):
                sadd(stdscr, by+3+i, bx+2, line[:bw-4], DM)
            if has_fix and pr.fix_label:
                sadd(stdscr, by+5, bx+2, f"Fix: {pr.fix_label}", DM)
            if has_fix:
                sadd(stdscr, by+bh-2, bx+2, " y = execute    n / ESC = cancel ", AC | curses.A_BOLD)
            else:
                sadd(stdscr, by+bh-2, bx+2, " press any key to dismiss ", AC | curses.A_BOLD)

        stdscr.refresh()

        # ── input handling ──────────────────────────────────────────────────────
        if _fix_busy.is_set():
            while stdscr.getch() != -1:
                pass
            if fix_msg:
                pass
        elif pending_fix is not None:
            idx, pr = pending_fix
            has_fix = pr.fix_fn is not None
            if has_fix and key in (ord('y'), ord('Y')) and not _fix_busy.is_set():
                _fix_busy.set()
                curses.flushinp()
                while stdscr.getch() != -1:
                    pass
                fix_msg = f"fixing: {pr.title}..."
                fix_msg_timer = time.time()
                threading.Thread(target=lambda p=pr: _run_fix(p), daemon=True).start()
                pending_fix = None
            elif has_fix and key in (ord('n'), ord('N'), 27):
                pending_fix = None
                fix_msg = "Cancelled"
                fix_msg_timer = time.time()
            elif ord('1') <= key <= ord('9'):
                fi = key - ord('1')
                if fi < len(fixable):
                    idx, pr = fixable[fi]
                    pending_fix = (idx, pr)
            elif not has_fix:
                pending_fix = None
            elif key in (ord('\n'), ord('\r')):
                pass
        elif not _fix_busy.is_set():
            if key == curses.KEY_UP and problems:
                sel = (sel - 1) % len(problems)
            elif key == curses.KEY_DOWN and problems:
                sel = (sel + 1) % len(problems)
            elif key in (ord('\n'), ord('\r')) and problems:
                pr = problems[sel]
                pending_fix = (sel, pr)
                fix_msg = f"Selected: {pr.title}"
                fix_msg_timer = time.time()
            elif key >= ord('1') and key <= ord('9'):
                fi = key - ord('1')
                if fi < len(fixable):
                    fi_idx, pr = fixable[fi]
                    sel = fi_idx
                    pending_fix = (fi_idx, pr)
                    fix_msg = f"Selected: {pr.title}"
                    fix_msg_timer = time.time()

def fix_worker(prob):
    try:
        r = prob.fix_fn()
        if r:
            prob.detail = str(r)[:80]
    except Exception as e:
        prob.detail = f"fix error: {e}"

def _run_fix(prob):
    try:
        fix_worker(prob)
    finally:
        time.sleep(0.5)
        _fix_busy.clear()

