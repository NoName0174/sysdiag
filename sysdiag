                sadd(p,3,2,"[ok] dmesg clean",OK)
        except Exception: pass

        # ── partitions ────────────────────────────────────────────────────────
        try:
            part_y = 1 + r1h + r2h + r3h + r4h
            ph = H - 1 - part_y
            if ph > 3:
                p = stdscr.derwin(ph, W, part_y, 0)
                draw_box(p, "partitions", AC, AC)
                mt=d.get("mem_total",1); mu=d.get("mem_used",0)
                st=d.get("swap_total",0); su=d.get("swap_used",0)
                sadd(p,1,2,f"ram: {gb(mu)}/{gb(mt)} GB",DM)
                sadd(p,1,22,f"swap: {gb(su)}/{gb(st)} GB",DM)
                y = 2
                for disk in disks:
                    if y >= ph - 1: break
                    label = f"  ({disk['label']})" if disk['label'] else ""
                    sadd(p, y, 2, f"{disk['name']}{label}  {disk['size']}", AC | curses.A_BOLD)
                    y += 1

                    for part in disk["parts"]:
                        if y >= ph - 1: break
                        is_unalloc = part["name"] == "unallocated"
                        name_short = part["name"].replace("/dev/","")
                        col = DM if is_unalloc else NM
                        if part.get("used_frac",0) > 0.90 and not is_unalloc:
                            col = ER | curses.A_BOLD

                        fields = [f"  {name_short}"]
                        if part["fstype"]: fields.append(part["fstype"])
                        fields.append(part["size"])
                        if part["used"]:  fields.append(f"used:{part['used']}")
                        if part["avail"]: fields.append(f"avail:{part['avail']}")
                        if part["label"]: fields.append(f"({part['label']})")

                        sadd(p, y, 2, "  ".join(fields)[:W-4], col)
                        y += 1

                        for mount in part["mounts"]:
                            if y >= ph - 1: break
                            sadd(p, y, 6, mount, DM)
                            y += 1

                    y += 1
        except Exception: pass

        sadd(stdscr, H-1, 0, f" q quit  --monitor  refresh every {REFRESH}s ".ljust(W), AC | curses.A_REVERSE)
        stdscr.refresh()

# ── draw dispatcher ──────────────────────────────────────────────────────────
def draw(stdscr, data_obj, monitor_mode, test_mode):
    if monitor_mode:
        draw_monitor(stdscr, data_obj)
    else:
        draw_default(stdscr, data_obj, test_mode)

# ── entry ─────────────────────────────────────────────────────────────────────
def main():
    monitor = "--monitor" in sys.argv
    test_mode = "--test" in sys.argv
    if not monitor:
        os.system("sudo -v")
    data = Data()
    try:
        curses.wrapper(lambda s: draw(s, data, monitor, test_mode))
    except KeyboardInterrupt:
        pass

if __name__ == "__main__":
    main()
