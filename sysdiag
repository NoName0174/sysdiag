        except Exception: pass

        # ── network + battery ─────────────────────────────────────────────────
        try:
            p = pan(2,"r"); ph,pw = p.getmaxyx()
            draw_box(p,"network & battery",AC,AC)
            iface = d.get("iface","?")
            sadd(p,1,2,f"iface: ",DM); sadd(p,1,9,iface,NM|curses.A_BOLD)
