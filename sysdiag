            p = pan(3,"r"); ph,pw = p.getmaxyx()
            draw_box(p,"kernel & firewall",AC,AC)
            sadd(p,1,2,"ports: ",DM); sadd(p,1,9,(d.get("ports","") or "none")[:pw-12],NM)
            sadd(p,2,2,f"fw rules (INPUT): {d.get('fw','?')}",DM)
            dw=d.get("dmesg",[])
