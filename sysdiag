#!/usr/bin/env fish
# sysdiag — full system diagnostic
# deps: fish, procps, iproute2, systemd, smartmontools, util-linux, bind/drill, iptables

# ── theme ─────────────────────────────────────────────────────────────────────
set accent (cat ~/.config/hypr/.border_color 2>/dev/null; or echo "e8730a")
switch $accent
    case "cc0000"; set c "\e[31m"
    case "ffffff"; set c "\e[97m"
    case "*";      set c "\e[38;5;208m"
end
set r "\e[0m"
set b "\e[1m"
set dim "\e[2m"
set w "\e[37m"
set red "\e[31m"
set grn "\e[32m"
set ylw "\e[33m"

function section -a title
    printf "\n$b$c ── $title$r\n"
end

function bar -a pct
    set filled (math "round($pct * 20 / 100)")
    set empty (math "20 - $filled")
    printf "$c"
    for i in (seq 1 $filled); printf "█"; end
    printf "$r$dim"
    for i in (seq 1 $empty); printf "░"; end
    printf "$r"
end

function ok;   printf "  $grn✔$r "; end
function warn; printf "  $ylw✘$r "; end
function err;  printf "  $red✘$r "; end

# ── cpu (aggregate + per-core) ────────────────────────────────────────────────
set cpu_raw  (grep "^cpu"  /proc/stat)
sleep 0.5
set cpu_raw2 (grep "^cpu"  /proc/stat)

set agg1  (echo $cpu_raw  | head -1 | awk '{print $2,$3,$4,$5}')
set agg2  (echo $cpu_raw2 | head -1 | awk '{print $2,$3,$4,$5}')
set t1 (echo $agg1 | awk '{print $1+$2+$3+$4}')
set i1 (echo $agg1 | awk '{print $4}')
set t2 (echo $agg2 | awk '{print $1+$2+$3+$4}')
set i2 (echo $agg2 | awk '{print $4}')
set cpu_pct (math "round(100*(($t2-$t1)-($i2-$i1))/($t2-$t1))")

set cores (nproc)
set per_core ""
for i in (seq 0 (math "$cores - 1"))
    set l1 (echo $cpu_raw  | grep -oP "cpu$i \K[\d ]+" | head -1)
    set l2 (echo $cpu_raw2 | grep -oP "cpu$i \K[\d ]+" | head -1)
    if test -n "$l1" -a -n "$l2"
        set ct1 (echo $l1 | awk '{print $1+$2+$3+$4}')
        set ci1 (echo $l1 | awk '{print $4}')
        set ct2 (echo $l2 | awk '{print $1+$2+$3+$4}')
        set ci2 (echo $l2 | awk '{print $4}')
        set dt (math "$ct2-$ct1")
        if test $dt -gt 0
            set cp (math "round(100*(($ct2-$ct1)-($ci2-$ci1))/($ct2-$ct1))")
        else
            set cp 0
        end
        set per_core $per_core "cpu$i:$cp%"
    end
end

set iowait (awk '/^cpu /{t=$2+$3+$4+$5+$6;iw=$6;printf "%.1f", iw/t*100}' /proc/stat)
set ctx    (awk '/^ctxt/{print $2}' /proc/stat)
set intr   (awk '/^intr/{print $2}' /proc/stat)

# ── temperature sensors ───────────────────────────────────────────────────────
set temps ""
for zone in /sys/class/thermal/thermal_zone*
    set type (cat $zone/type 2>/dev/null)
    set temp (cat $zone/temp 2>/dev/null)
    if test -n "$temp"
        set tc (math "round($temp/1000)")
        set temps $temps "$type:$tc°C"
    end
end
set hwmon_temps ""
for f in /sys/class/hwmon/hwmon*/temp*_input
    set lbl (string replace "_input" "_label" $f)
    set name (cat $lbl 2>/dev/null; or echo (basename $f))
    set val (cat $f 2>/dev/null)
    if test -n "$val"
        set tc (math "round($val/1000)")
        set hwmon_temps $hwmon_temps "$name:$tc°C"
    end
end

# ── fan speeds ────────────────────────────────────────────────────────────────
set fans ""
for f in /sys/class/hwmon/hwmon*/fan*_input
    set lbl (string replace "_input" "_label" $f)
    set name (cat $lbl 2>/dev/null; or echo (basename $f))
    set val (cat $f 2>/dev/null)
    test -n "$val"; and set fans $fans "$name:$val RPM"
end

# ── memory ────────────────────────────────────────────────────────────────────
set mem_total (grep MemTotal     /proc/meminfo | awk '{print $2}')
set mem_avail (grep MemAvailable /proc/meminfo | awk '{print $2}')
set mem_used  (math "$mem_total - $mem_avail")
set mem_pct   (math "round($mem_used*100/$mem_total)")
set mem_used_gb  (math "round($mem_used/1024/1024*10)/10")
set mem_total_gb (math "round($mem_total/1024/1024*10)/10")
set dirty     (grep "^Dirty:"      /proc/meminfo | awk '{print $2}')
set writeback (grep "^Writeback:"  /proc/meminfo | awk '{print $2}')
set huge_total (grep HugePages_Total /proc/meminfo | awk '{print $2}')
set huge_free  (grep HugePages_Free  /proc/meminfo | awk '{print $2}')
set dirty_mb  (math "round($dirty/1024)")
set wb_mb     (math "round($writeback/1024)")

# memory errors
set mem_errors (grep -r "CE\|UE" /sys/devices/system/edac/mc/*/ce_count /sys/devices/system/edac/mc/*/ue_count 2>/dev/null | awk -F: '{sum+=$2} END{print sum+0}')

# ── processes ─────────────────────────────────────────────────────────────────
set top_cpu (ps --no-headers -eo pid,comm,%cpu --sort=-%cpu | head -5)
set zombies (ps --no-headers -eo stat | grep -c "^Z")
set oom_events (journalctl -k --since "today" 2>/dev/null | grep -c "Out of memory\|oom_kill" || echo 0)
set sched_lat (awk '/se.statistics.wait_max/{print $2}' /proc/$(pgrep -n fish)/sched 2>/dev/null; or echo "n/a")

# ── systemd ───────────────────────────────────────────────────────────────────
set failed_units (systemctl --failed --no-legend 2>/dev/null | awk '{print $1}')
set journal_errs (journalctl -p err -n 5 --no-pager --no-hostname -o short 2>/dev/null | tail -5)

# ── dmesg ─────────────────────────────────────────────────────────────────────
set dmesg_warn (dmesg --level=warn,err,crit,alert,emerg 2>/dev/null | tail -8)

# ── gpu ───────────────────────────────────────────────────────────────────────
set gpu_info ""
if command -q nvidia-smi
    set gpu_info (nvidia-smi --query-gpu=name,utilization.gpu,temperature.gpu,memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null)
else if test -f /sys/class/drm/card0/device/gpu_busy_percent
    set gpu_pct (cat /sys/class/drm/card0/device/gpu_busy_percent)
    set gpu_info "Intel/AMD integrated · $gpu_pct% busy"
else
    set gpu_info "no GPU data available"
end

# ── nvme/ssd health ───────────────────────────────────────────────────────────
set smart_info ""
for dev in /dev/nvme0 /dev/sda /dev/sdb
    if test -e $dev
        set s (sudo smartctl -H $dev 2>/dev/null | grep "overall-health\|result" | awk -F: '{print $2}')
        test -n "$s"; and set smart_info $smart_info "$dev:$s"
    end
end
test -z "$smart_info"; and set smart_info "run as root for SMART"

# ── network ───────────────────────────────────────────────────────────────────
set iface   (ip route get 1.1.1.1 2>/dev/null | awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}')
set ip_addr (ip -4 addr show $iface 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1)
set gw      (ip route | awk '/default/{print $3}' | head -1)

set ping_gw  (ping -c1 -W1 $gw      2>/dev/null | awk -F'/' '/rtt/{print $5"ms"}'; or echo "timeout")
set ping_ext (ping -c1 -W1 1.1.1.1  2>/dev/null | awk -F'/' '/rtt/{print $5"ms"}'; or echo "timeout")
set dns_time (fish -c 'set t (date +%s%3N); drill archlinux.org @1.1.1.1 >/dev/null 2>&1; math (date +%s%3N) - $t' 2>/dev/null; or echo "n/a")

set fw_status (sudo iptables -L INPUT -n 2>/dev/null | grep -c "^ACCEPT\|^DROP\|^REJECT"; or echo "n/a")
set open_ports (ss -tlnp 2>/dev/null | awk 'NR>1{print $4}' | grep -oP ':\K\d+' | sort -n | tr '\n' ' ')

# ── security ──────────────────────────────────────────────────────────────────
set last_logins (last -n 4 --time-format iso 2>/dev/null | head -4)
set ssh_fails   (journalctl _SYSTEMD_UNIT=sshd.service 2>/dev/null | grep -c "Failed password\|Invalid user"; or echo 0)
set suid_count  (find /usr/bin /usr/sbin /bin /sbin -perm /4000 2>/dev/null | wc -l)
set updates     (checkupdates 2>/dev/null | wc -l; or echo "n/a")

# ── render ────────────────────────────────────────────────────────────────────
clear
printf "$b$c lapsa@cachyos $r$dim · hyprland · wayland · $(date '+%A %d %B %Y  %H:%M:%S')$r\n"
printf "$dim────────────────────────────────────────────────────────────$r\n"

section "cpu"
printf "  total: $w%s%%$r  iowait: $w%s%%$r  cores: $w%s$r\n" $cpu_pct $iowait $cores
printf "  "; bar $cpu_pct; printf "\n"
printf "  $dim per-core: $r"
for c in $per_core; printf "$dim%s$r  " $c; end; printf "\n"
printf "  $dim ctx switches: $r$w%s$r  interrupts: $w%s$r\n" $ctx $intr

section "memory"
printf "  $w%s / %s GB$r  ($w%s%%%r used)\n" $mem_used_gb $mem_total_gb $mem_pct
printf "  "; bar $mem_pct; printf "\n"
printf "  $dim dirty: $r$w%s MB$r  writeback: $w%s MB$r  hugepages: $w%s free / %s$r\n" $dirty_mb $wb_mb $huge_free $huge_total
if test $mem_errors -gt 0
    err; printf "memory errors (edac): $red%s$r\n" $mem_errors
else
    ok;  printf "$dim no memory errors$r\n"
end

section "temperatures"
printf "  "
for t in $temps; printf "$w%s$r  " $t; end; printf "\n"
if test -n "$hwmon_temps"
    printf "  "
    for t in $hwmon_temps; printf "$dim%s$r  " $t; end; printf "\n"
end

section "fans"
if test -n "$fans"
    printf "  "
    for f in $fans; printf "$w%s$r  " $f; end; printf "\n"
else
    printf "  $dim no fan data (thinkpad_acpi may need loading)$r\n"
end

section "gpu"
printf "  $w%s$r\n" $gpu_info

section "storage · smart"
for s in $smart_info
    set dev (string split ":" $s)[1]
    set status (string split ":" $s)[2]
    if string match -q "*PASSED*" $status
        ok; printf "%s  $grn%s$r\n" $dev $status
    else
        err; printf "%s  $red%s$r\n" $dev $status
    end
end

section "processes"
printf "  $dim%5s  %-20s  %s$r\n" "PID" "NAME" "CPU%"
echo $top_cpu | while read -l pid name pct
    printf "  %5s  %-20s  $w%s%%$r\n" $pid $name $pct
end
printf "  $dim zombies: $r"; test $zombies -gt 0; and printf "$red%s$r\n" $zombies; or printf "$grn0$r\n"
printf "  $dim oom kills today: $r"; test $oom_events -gt 0; and printf "$red%s$r\n" $oom_events; or printf "$grn0$r\n"

section "systemd"
if test -z "$failed_units"
    ok; printf "$dim no failed units$r\n"
else
    for u in $failed_units
        err; printf "$red%s$r\n" $u
    end
end

section "journal errors (last 5)"
if test -n "$journal_errs"
    echo $journal_errs | while read -l line
        printf "  $red%s$r\n" $line
    end
else
    ok; printf "$dim no recent errors$r\n"
end

section "dmesg (warn+)"
if test -n "$dmesg_warn"
    echo $dmesg_warn | while read -l line
        printf "  $ylw%s$r\n" $line
    end
else
    ok; printf "$dim clean$r\n"
end

section "network"
printf "  iface: $w%s$r  ip: $w%s$r  gw: $w%s$r\n" $iface $ip_addr $gw
printf "  ping gw: $w%s$r  ping 1.1.1.1: $w%s$r  dns: $w%sms$r\n" $ping_gw $ping_ext $dns_time
printf "  open ports: $dim%s$r\n" $open_ports
printf "  firewall rules (INPUT): $w%s$r\n" $fw_status

section "security"
printf "  suid binaries: $w%s$r  ssh failures: $w%s$r  pending updates: $w%s$r\n" $suid_count $ssh_fails $updates
printf "\n  $dim last logins:$r\n"
echo $last_logins | while read -l line
    printf "  $dim%s$r\n" $line
end

printf "\n$dim────────────────────────────────────────────────────────────$r\n"
if contains -- -w $argv
    printf "$dim watching · refresh every 10s · ctrl-c to exit$r\n"
    sleep 10
    exec fish (status filename) $argv
else
    printf "$dim run with -w to watch$r\n"
end
