        disks  = d.get("disks",[])
        part_lines = sum(1 + len(dk["parts"]) + sum(len(pt["mounts"]) for pt in dk["parts"]) for dk in disks)
        part_h = max(4, min(part_lines + 2, usable // 2))
        top_h  = usable - part_h

        r1h = max(6, top_h * 22 // 100)
        r2h = max(6, top_h * 18 // 100)
        r3h = max(7, top_h * 25 // 100)
        r4h = max(6, top_h - r1h - r2h - r3h)

        lw = W * 55 // 100
        rw = W - lw
        ry = [1, 1+r1h, 1+r1h+r2h, 1+r1h+r2h+r3h]

        def pan(ri, side):
            h = [r1h,r2h,r3h,r4h][ri]
            return stdscr.derwin(h, lw, ry[ri], 0) if side=="l" else stdscr.derwin(h, rw, ry[ri], lw)

        # ── cpu ───────────────────────────────────────────────────────────────
        try:
            p = pan(0,"l"); ph,pw = p.getmaxyx()
            draw_box(p,"cpu",AC,AC)
            pct = d.get("cpu_pct",0)
            sadd(p,1,2,f"total: ",DM); sadd(p,1,9,f"{pct}%",NM|curses.A_BOLD)
            sadd(p,1,13,f"  iowait: {d.get('iowait','?')}%  freq: {d.get('cpu_freq','?')}",DM)
            sadd(p,2,2,bar(pct,pw-4),AC)
            cores = d.get("cpu_cores",[])
            core_str = "  ".join(f"c{i}:{cp}%" for i,cp in enumerate(cores))
            sadd(p,3,2,core_str[:pw-4],DM)
            hist = d.get("cpu_hist",[])
            if hist and pw > 8:
                sadd(p,ph-2,2,sparkline(hist, pw-4)[:pw-4],AC)
        except Exception: pass

        # ── memory ────────────────────────────────────────────────────────────
        try:
            p = pan(0,"r"); ph,pw = p.getmaxyx()
            draw_box(p,"memory",AC,AC)
            mt=d.get("mem_total",1); mu=d.get("mem_used",0); mp=d.get("mem_pct",0)
            sadd(p,1,2,f"{gb(mu)} / {gb(mt)} GB  ({mp}%)",NM|curses.A_BOLD)
            sadd(p,2,2,bar(mp,pw-4),AC)
            st=d.get("swap_total",0); su=d.get("swap_used",0)
            sp=round(su*100/st) if st else 0
            sadd(p,3,2,f"swap: {gb(su)}/{gb(st)} GB ",DM)
            sadd(p,3,20,bar(sp,pw-22),AC)
            sadd(p,4,2,f"dirty: {d.get('dirty_mb',0)} MB  wb: {d.get('wb_mb',0)} MB  huge: {d.get('huge_free',0)}/{d.get('huge_total',0)}",DM)
            errs=d.get("mem_errors",0)
            sadd(p,5,2,"[ok] no memory errors" if not errs else f"[!!] edac errors: {errs}", OK if not errs else ER)
            hist = d.get("mem_hist",[])
            if hist and pw > 8 and ph > 6:
                sadd(p,ph-2,2,sparkline(hist, pw-4)[:pw-4],AC)
        except Exception: pass

        # ── temps & fans ──────────────────────────────────────────────────────
        try:
            p = pan(1,"l"); ph,pw = p.getmaxyx()
            draw_box(p,"temperatures & fans",AC,AC)
            x,y = 2,1
            for t in d.get("temps",[]):
                lbl,val = t.rsplit(":",1)
                tc = int(re.sub(r"[^\d]","",val))
                col = ER if tc>80 else WN if tc>65 else OK
                txt = f"{lbl[:12]}:{val}  "
                if x+len(txt)>pw-2: x=2; y+=1
                if y>=ph-2: break
                sadd(p,y,x,f"{lbl[:12]}:",DM)
                sadd(p,y,x+len(lbl[:12])+1,val,col|curses.A_BOLD)
                x+=len(txt)
            y+=1
            fans=d.get("fans",[])
            sadd(p,y,2,("fans: "+"  ".join(fans)) if fans else "fans: no data",DM)
        except Exception: pass

        # ── disk i/o + smart ─────────────────────────────────────────────────
        try:
            p = pan(1,"r"); ph,pw = p.getmaxyx()
            draw_box(p,"disk i/o & smart",AC,AC)
            disk_rates = d.get("disk_rates", {})
