            sadd(p,y,2,"smart:",DM); y += 1
            for dev,result in d.get("smart",[]):
                col = OK if "PASSED" in result.upper() else ER
                sadd(p,y,2,dev,DM); sadd(p,y,2+len(dev)+1,result,col|curses.A_BOLD)
                y+=1
                if y>=ph-1: break
        except Exception: pass

        # ── processes ─────────────────────────────────────────────────────────
        try:
            p = pan(2,"l"); ph,pw = p.getmaxyx()
            draw_box(p,"processes",AC,AC)
            sadd(p,1,2,f"{'PID':>6}  {'NAME':<20}  {'CPU%':>5}",DM)
