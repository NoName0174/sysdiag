            continue
        stdscr.erase()

        hn = sh("uname -n")
        load = d.get("load","")
        upt = d.get("uptime_days",0)
        ts = time.strftime("%H:%M:%S")
        sadd(stdscr, 0, 0, f" sysdiag --monitor  {hn}  {load}  uptime:{upt:.1f}d  {ts} ".center(W), AC | curses.A_BOLD)

