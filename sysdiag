# ── accent ────────────────────────────────────────────────────────────────────
def load_accent():
    try:
        h = Path("~/.config/sysdiag/accent").expanduser().read_text().strip()
        return int(h[0:2],16), int(h[2:4],16), int(h[4:6],16)
    except Exception:
        return None

# ── helpers ───────────────────────────────────────────────────────────────────
def sh(cmd, fallback=""):
    try:
        return subprocess.check_output(cmd, shell=True, stderr=subprocess.DEVNULL, timeout=3).decode().strip()
    except Exception:
        return fallback

def sh_bg(cmd):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=15)
        return (r.stdout.strip() or r.stderr.strip() or "done")[:120]
    except subprocess.TimeoutExpired:
        return "timed out"
    except Exception as e:
        return f"error: {e}"

def read(path, fallback=""):
    try:
        return Path(path).read_text().strip()
    except Exception:
        return fallback

def human(b):
    for u in ["B","KB","MB","GB","TB"]:
        if b < 1024: return f"{b:.2f} {u}"
        b /= 1024
    return f"{b:.2f} PB"

def human_rate(b):
    for u in ["B/s","KB/s","MB/s","GB/s"]:
        if b < 1024: return f"{b:.2f} {u}"
        b /= 1024
    return f"{b:.2f} PB/s"

def gb(kb):
    return f"{kb/1024/1024:.1f}"

def bar(pct, w):
    f = round(pct * w / 100)
    return "#" * f + "." * (w - f)

SPARK = "▁▂▃▄▅▆▇█"
def sparkline(vals, w):
    if not vals:
        return " " * w
    lo, hi = min(vals), max(vals)
    rng = hi - lo
    out = ""
    for v in vals:
        if rng == 0:
            out += SPARK[len(SPARK)//2]
        else:
            out += SPARK[min(len(SPARK)-1, int((v-lo) * (len(SPARK)-1) / rng))]
    return out[:w].ljust(w)

def sadd(win, y, x, text, attr=0):
    try:
        h, w = win.getmaxyx()
        if y < 0 or y >= h or x < 0: return
        if x >= w: return
        win.addstr(y, x, str(text)[:w-x], attr)
    except curses.error:
        pass

def draw_box(win, title, cp_bdr, cp_title):
    try:
        h, w = win.getmaxyx()
        win.attron(cp_bdr)
        win.border()
        for r in range(1, h-1):
            win.addstr(r, 1, " " * (w-2))
        win.attroff(cp_bdr)
        if title:
            win.attron(cp_title | curses.A_BOLD)
            win.addstr(0, 2, f" {title} "[:w-4])
            win.attroff(cp_title | curses.A_BOLD)
    except curses.error:
        pass

# ── problem detection ─────────────────────────────────────────────────────────
SEV_INFO = 0
SEV_WARN = 1
SEV_CRIT = 2

class Problem:
    __slots__ = ("severity","title","detail","fix_label","fix_fn")
    def __init__(self, severity, title, detail, fix_label=None, fix_fn=None):
        self.severity = severity
        self.title = title
        self.detail = detail
        self.fix_label = fix_label
        self.fix_fn = fix_fn

def detect_problems(d):
    p = []

    for dev, result in d.get("smart", []):
        if "PASSED" not in result.upper():
            p.append(Problem(SEV_CRIT, f"SMART FAILED: {dev}",
                "Drive may fail soon. Back up immediately!",
                "backup tips", lambda dev=dev: f"sudo dd if={dev} of=/backup/image.img status=progress"))

    for t in d.get("temps", []):
        if ":" in t:
            lbl, val = t.rsplit(":", 1)
            tc = int(re.sub(r"[^\d]", "", val))
            if tc > 85:
                p.append(Problem(SEV_CRIT, f"{tc}°C {lbl}",
                    "Critical temp! Check fans, clean heatsink, repaste CPU.",
                    "sensors", lambda: sh_bg("sensors 2>/dev/null | head -20")))
            elif tc > 70:
                p.append(Problem(SEV_WARN, f"{tc}°C {lbl}",
                    "High temperature. Monitor closely.",
                    "sensors", lambda: sh_bg("sensors 2>/dev/null | head -20")))

    errs = d.get("mem_errors", 0)
    if errs > 0:
        p.append(Problem(SEV_CRIT, f"{errs} EDAC memory error(s)",
            "Run memtest86, reseat RAM modules, check for bad DIMMs.",
            "edac report", lambda: sh_bg("grep . /sys/devices/system/edac/mc/*/{ce,ue}_count 2>/dev/null | head -10")))

    wear = d.get("battery_wear", 0)
    if wear > 20:
        p.append(Problem(SEV_WARN, f"Battery worn {wear:.0f}%",
            f"Design: {d.get('battery_design',0)}Wh, current: {d.get('battery_now',0)}Wh. Replace soon.",
            "battery info", lambda: sh_bg("upower -i /org/freedesktop/UPower/devices/battery_BAT0 2>/dev/null | head -15")))

    if wear > 0 and d.get("battery_status","") == "Discharging" and d.get("battery_now",0) < 15:
        p.append(Problem(SEV_WARN, f"Battery low ({d.get('battery_now',0)}%)",
            "Plug in charger."))

    fu = d.get("failed_units", [])
    if fu:
        names = " ".join(u.split()[0] for u in fu[:3])
        p.append(Problem(SEV_CRIT, f"{len(fu)} failed systemd unit(s)",
            f"Failed: {names}",
            "restart all", lambda: sh_bg("systemctl restart " + " ".join(u.split()[0] for u in fu))))

    z = int(d.get("zombies", 0))
    if z > 0:
        p.append(Problem(SEV_WARN, f"{z} zombie process(es)",
            "Zombies consume PID table slots. Kill parent processes.",
            "reap zombies", lambda: sh_bg("ps --no-headers -eo pid,stat | awk '/Z/{print $1}' | xargs -r kill -9")))

    oom = int(d.get("oom_events", 0))
    if oom > 3:
        p.append(Problem(SEV_CRIT, f"{oom} OOM kill(s) today",
            "Out of memory! Add swap or adjust vm.overcommit_ratio.",
            "check memory", lambda: sh_bg("free -h; echo ---; vmstat -s 2>/dev/null | head -10")))
    elif oom > 0:
        p.append(Problem(SEV_WARN, f"{oom} OOM kill(s) today",
            "Monitor memory pressure. Consider adding swap.",
            "check swap", lambda: sh_bg("free -h; swapon --show")))

    js = d.get("journal_size_mb", 0)
    if js > 500:
        p.append(Problem(SEV_WARN, f"Journal {js:.0f} MB",
            "Systemd journal is large.",
            "vacuum to 200M", lambda: sh_bg("journalctl --vacuum-size=200M")))

    for disk in d.get("disks", []):
        for part in disk["parts"]:
            pct_used = part.get("used_frac", 0)
            if pct_used > 0.90 and pct_used > 0:
                name = part["name"].replace("/dev/","")
                p.append(Problem(SEV_CRIT, f"{name} at {pct_used*100:.0f}% capacity",
                    f"Low disk space. Clean up!",
                    "auto-clean", lambda: sh_bg("sudo pacman -Sc; paccache -r; journalctl --vacuum-size=200M")))

    dns = d.get("dns_ms", "")
    if dns.replace(".","",1).lstrip("-").isdigit() and float(dns) > 1000:
        p.append(Problem(SEV_WARN, f"DNS slow ({dns}ms)",
            "Try: drill archlinux.org @8.8.8.8",
            "test 1.1.1.1", lambda: sh_bg("drill archlinux.org @1.1.1.1 2>&1 | head -5")))
    elif dns == "n/a":
        p.append(Problem(SEV_WARN, "DNS resolution failed",
            "Check connectivity or resolver config.",
            "test 1.1.1.1", lambda: sh_bg("drill archlinux.org @1.1.1.1 2>&1 | head -5")))

    sf = int(d.get("ssh_fails", 0))
    if sf > 10:
        p.append(Problem(SEV_CRIT, f"{sf} SSH auth failures",
            "Consider fail2ban or disable password auth.",
            "security tips", lambda: "Install: sudo pacman -S fail2ban; enable: sudo systemctl enable --now fail2ban"))

    upt = d.get("uptime_days", 0)
    if upt > 60:
        p.append(Problem(SEV_INFO, f"Uptime {upt:.0f} days",
            "Long uptime — consider rebooting for kernel updates.",
            "reboot?", lambda: "sudo reboot"))

    return p

_test_problems = []

def _rm(prob, msg):
    def fn():
        global _test_problems
        try:
            _test_problems.remove(prob)
        except ValueError:
            pass
        return f"[fixed] {msg}"
    return fn

def test_problems():
    global _test_problems
    if _test_problems:
        return _test_problems
    items = [
        (SEV_CRIT, "SMART FAILED: /dev/sda",
         "Simulated drive failure — back up immediately.",                          "backup tips",    "simulated: dd backup"),
        (SEV_CRIT, "91°C x86_pkg_temp",
         "Simulated critical temp — check cooling.",                                "sensors",        "simulated: sensors output"),
        (SEV_CRIT, "12 EDAC memory error(s)",
         "Simulated memory errors — run memtest86.",                                "edac report",    "simulated: edac report"),
        (SEV_WARN, "Battery worn 30%",
         "Simulated: Design 50.0Wh, current 35.0Wh.",                              "battery info",   "simulated: battery report"),
        (SEV_CRIT, "3 failed systemd unit(s)",
         "Simulated: sshd.service, NetworkManager.service failed.",                 "restart all",    "simulated: systemctl restart"),
        (SEV_WARN, "5 zombie process(es)",
         "Simulated zombies — reap them.",                                          "reap zombies",   "simulated: reaped 5 zombies"),
        (SEV_CRIT, "8 OOM kill(s) today",
         "Simulated out-of-memory events.",                                         "check memory",   "simulated: memory check"),
        (SEV_WARN, "Journal 800 MB",
         "Simulated oversized journal.",                                            "vacuum to 200M", "simulated: journal vacuum"),
        (SEV_CRIT, "sda1 at 95% capacity",
         "Simulated disk full.",                                                    "auto-clean",     "simulated: disk cleanup"),
        (SEV_WARN, "DNS slow (2340ms)",
         "Simulated slow DNS resolution.",                                          "test 1.1.1.1",   "simulated: DNS test"),
        (SEV_CRIT, "12 SSH auth failures",
         "Simulated brute-force attempts.",                                         "security tips",  "simulated: fail2ban install"),
        (SEV_INFO, "Uptime 120 days",
         "Simulated long uptime — reboot for kernel updates.",                      "reboot?",        "simulated: reboot"),
